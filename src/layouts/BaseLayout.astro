---
const { title = 'Dishwasher Safe?', description = 'Fast answers for what can and cannot go in the dishwasher.', canonical: canonicalOverride, noindex = false } = Astro.props;
const canonical = canonicalOverride ?? new URL(Astro.url.pathname, Astro.site).toString();
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const shouldLoadGA = typeof gaMeasurementId === 'string' && /^G-[A-Z0-9]+$/.test(gaMeasurementId);
const shouldShowGoogleVerification = typeof googleSiteVerification === 'string' && googleSiteVerification.length > 0;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#F7F7F2" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {shouldShowGoogleVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    {shouldLoadGA && (<><script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script><script is:inline define:vars={{ gaMeasurementId }}>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config',gaMeasurementId);</script></>)}
    <style is:global>
      :root{--cream:#F7F7F2;--cream-2:#EAF4F1;--ink:#13243A;--muted:#5C6B7A;--line:#DDE5E1;--paper:#fff;--accent-teal:#2B8C7E;--accent-teal-tint:#D8EFEA;--accent-gold:#F0A34A;--accent-gold-tint:#FCEBCC;--danger:#B9543B;--radius:16px;--shadow:0 14px 36px rgba(19,36,58,.08);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;color-scheme:light}
      *{box-sizing:border-box}body{margin:0;background:var(--cream);color:var(--ink);-webkit-font-smoothing:antialiased}a{color:inherit;text-decoration:none}a:hover{color:var(--accent-teal)}p,h1,h2,h3{margin:0}svg{display:block}.page{min-height:100vh;background:radial-gradient(900px 280px at 50% -120px,#D9ECE8,transparent 65%),var(--cream)}.site-header,.site-footer,main{max-width:980px;margin:0 auto}.site-header{padding:18px 20px 8px;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}.brand{display:flex;align-items:center;gap:10px;font-weight:800;font-size:19px}.brand-mark{width:38px;height:38px;border:2px solid var(--ink);background:var(--paper);border-radius:12px;display:grid;place-items:center;box-shadow:0 3px 0 rgba(19,36,58,.08)}.brand span span{color:var(--accent-teal)}.nav{display:flex;gap:4px;flex-wrap:wrap}.nav a{font-size:14px;color:var(--muted);font-weight:650;padding:8px 12px;border-radius:999px}.nav a:hover{background:var(--paper);color:var(--ink)}main{padding:16px 20px 64px;display:flex;flex-direction:column;gap:36px}.site-footer{padding:24px 20px 36px;border-top:1px solid var(--line);font-size:13px;color:var(--muted)}.breadcrumbs{display:flex;gap:6px;flex-wrap:wrap;color:var(--muted);font-size:13px}.hero{padding:42px 0 20px;display:grid;gap:16px}.eyebrow{display:inline-flex;align-items:center;gap:8px;color:var(--accent-teal);font-weight:800;font-size:13px;text-transform:uppercase;letter-spacing:.08em}.dot{width:9px;height:9px;border-radius:50%;background:var(--accent-gold)}.hero h1{font-size:clamp(38px,7vw,72px);letter-spacing:-.05em;line-height:.94;max-width:760px}.hero h1 em{font-style:normal;color:var(--accent-teal)}.hero p{font-size:clamp(17px,2vw,21px);line-height:1.55;color:var(--muted);max-width:680px}.pills{display:flex;gap:8px;flex-wrap:wrap}.pills span,.chip{background:var(--paper);border:1px solid var(--line);border-radius:999px;padding:7px 11px;font-size:13px;font-weight:650;color:var(--muted)}.section{display:grid;gap:15px}.section-head{display:grid;gap:4px}.section h1,.section h2{font-size:clamp(23px,3vw,31px);letter-spacing:-.025em}.section-head p,.section>p{color:var(--muted);line-height:1.55}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(245px,1fr));gap:12px}.card{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);padding:16px;display:grid;gap:10px;box-shadow:0 1px 0 rgba(19,36,58,.03);transition:.18s}.card:hover{transform:translateY(-2px);box-shadow:var(--shadow);border-color:var(--ink)}.card strong{font-size:18px;letter-spacing:-.01em}.card p{color:var(--muted);font-size:14px;line-height:1.48}.icon-badge{width:52px;height:52px;border-radius:15px;background:var(--accent-teal-tint);display:grid;place-items:center;color:var(--ink)}.answer-card{background:var(--ink);color:var(--cream);border-radius:24px;padding:clamp(22px,4vw,34px);display:grid;gap:18px;box-shadow:var(--shadow);position:relative;overflow:hidden}.answer-card::before{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.06) 1px,transparent 1px);background-size:14px 14px;pointer-events:none}.answer-card>*{position:relative}.verdict{display:inline-flex;width:max-content;align-items:center;gap:8px;border-radius:999px;padding:8px 12px;font-size:13px;font-weight:800;background:rgba(255,255,255,.1)}.verdict.yes,.verdict.top-rack{background:var(--accent-teal-tint);color:var(--ink)}.verdict.no{background:#F8DDD5;color:var(--ink)}.verdict.depends{background:var(--accent-gold-tint);color:var(--ink)}.answer-card h1{font-size:clamp(30px,5vw,48px);line-height:1;letter-spacing:-.04em}.answer-text{font-size:clamp(17px,2vw,20px);line-height:1.55;color:rgba(247,247,242,.9);max-width:72ch}.updated-line{font-size:13px;color:rgba(247,247,242,.68);font-weight:700;letter-spacing:.01em}.tiles{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.tile{background:var(--paper);color:var(--ink);border-radius:16px;padding:14px;display:grid;gap:5px}.tile-label{font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-weight:800}.tile-value{font-weight:800;line-height:1.25}.caveats{list-style:none;margin:0;padding:0;display:grid;gap:8px}.caveats li{display:grid;grid-template-columns:auto 1fr;gap:10px;align-items:start;background:var(--paper);border:1px solid var(--line);border-left:4px solid var(--accent-gold);border-radius:14px;padding:14px;color:var(--muted);line-height:1.5}.link-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:10px}.link-card{display:grid;grid-template-columns:1fr auto;gap:12px;align-items:center;background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:14px 16px;font-weight:750}.faq details{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:14px 16px;margin-top:8px}.faq summary{font-weight:800;cursor:pointer}.faq p{margin-top:10px;color:var(--muted);line-height:1.55}@media(max-width:640px){.tiles{grid-template-columns:1fr}.hero{padding-top:28px}.site-header{align-items:flex-start}}
    </style>
  </head>
  <body><div class="page"><header class="site-header"><a class="brand" href="/"><span class="brand-mark">↯</span><span>Dishwasher <span>Safe?</span></span></a><nav class="nav"><a href="/items/">Items</a><a href="/materials/">Materials</a><a href="/can-you/">Can you?</a><a href="/privacy/">Privacy</a></nav></header><main><slot /></main><footer class="site-footer">Dishwasher Safe? gives general household guidance. Always follow the manufacturer’s care instructions for your exact item.</footer></div></body>
</html>

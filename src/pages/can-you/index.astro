---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { items, verdictLabels } from '../../data/items';
---
<BaseLayout title="Can you put it in the dishwasher?" description="Yes/no dishwasher-safe answers for bottles, cookware, lids, baby gear, and kitchen items.">
  <nav class="breadcrumbs"><a href="/">Home</a><span>/</span><span>Can you?</span></nav>
  <section class="section">
    <div class="section-head"><h2>Can you put it in the dishwasher?</h2><p>Question-shaped pages for quick answers.</p></div>
    <div class="grid">
      {items.map((item)=>(
        <a class="card" href={`/can-you/${item.slug}/`}><span class="icon-badge"><Icon name="rack" /></span><strong>Can you put {item.name} in the dishwasher?</strong><p><span class="chip">{verdictLabels[item.verdict]}</span></p><p>{item.shortAnswer}</p></a>
      ))}
    </div>
  </section>
</BaseLayout>

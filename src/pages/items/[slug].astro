---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { findItem, items, verdictLabels, findMaterial } from '../../data/items';
export function getStaticPaths(){ return items.map((item)=>({ params:{ slug:item.slug }})); }
const item = findItem(Astro.params.slug!); if(!item) throw new Error('Item not found');
const title = `Can you put ${item.name} in the dishwasher?`;
const updatedLabel = 'Updated May 4, 2026';
const description = `${item.shortAnswer} Includes rack placement, cycle, drying, and caveats.`;
const verdictClass = item.verdict === 'top-rack' ? 'top-rack' : item.verdict;
const faqSchema = {'@context':'https://schema.org','@type':'FAQPage',mainEntity:[{'@type':'Question',name:title,acceptedAnswer:{'@type':'Answer',text:item.shortAnswer}},{'@type':'Question',name:`Where should ${item.name} go in the dishwasher?`,acceptedAnswer:{'@type':'Answer',text:item.placement}}]};
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><a href="/items/">Items</a><span aria-hidden="true">/</span><span aria-current="page">{item.name}</span></nav>
  <article class="section">
    <section class="answer-card">
      <span class={`verdict ${verdictClass}`}><Icon name={item.verdict === 'no' ? 'warning' : 'check'} />{verdictLabels[item.verdict]}</span>
      <h1>{title}</h1>
      <p class="answer-text">{item.shortAnswer}</p>
      <p class="updated-line">{updatedLabel}</p>
      <div class="tiles"><div class="tile"><span class="tile-label">Rack</span><span class="tile-value">{item.placement}</span></div><div class="tile"><span class="tile-label">Cycle</span><span class="tile-value">{item.cycle}</span></div><div class="tile"><span class="tile-label">Drying</span><span class="tile-value">{item.dry}</span></div></div>
    </section>
    <section class="section"><h2>Why</h2><p>{item.why}</p></section>
    <section class="section"><h2><Icon name="warning" /> Caveats</h2><ul class="caveats">{item.caveats.map((c)=><li><Icon name="warning" /><span>{c}</span></li>)}</ul></section>
    <section class="section"><h2>Related materials</h2><div class="link-row">{item.materials.map((slug)=>{ const material = findMaterial(slug); return material && <a class="link-card" href={`/materials/${material.slug}/`}><span>{material.name}</span><Icon name="arrow" /></a>; })}</div></section>
    <section class="section faq"><h2>FAQ</h2><details open><summary>Can {item.name} go on the bottom rack?</summary><p>{item.placement}</p></details><details><summary>Can you use heated dry?</summary><p>{item.dry}</p></details></section>
  </article>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { items, verdictLabels } from '../../data/items';
---
<BaseLayout title="Dishwasher-safe answers by item" description="Browse dishwasher-safe guidance for common kitchen items, bottles, lids, cookware, and baby gear.">
  <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span aria-hidden="true">/</span><span aria-current="page">Items</span></nav>
  <section class="section">
    <div class="section-head"><h2>Dishwasher-safe answers by item</h2><p>Choose the thing you’re about to wash.</p></div>
    <div class="grid">
      {items.map((item) => (
        <a class="card" href={`/items/${item.slug}/`}>
          <span class="icon-badge"><Icon name="dishwasher" /></span>
          <strong>{item.name}</strong>
          <p><span class="chip">{verdictLabels[item.verdict]}</span></p>
          <p>{item.shortAnswer}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

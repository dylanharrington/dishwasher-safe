---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { findMaterial, materials, itemsForMaterial, verdictLabels } from '../../data/items';
export function getStaticPaths(){ return materials.map((material)=>({ params:{ slug:material.slug }})); }
const material = findMaterial(Astro.params.slug!); if(!material) throw new Error('Material not found');
const related = itemsForMaterial(material.slug);
const title = `Is ${material.name} dishwasher safe?`;
const description = material.shortAnswer;
const verdictClass = material.defaultVerdict === 'top-rack' ? 'top-rack' : material.defaultVerdict;
---
<BaseLayout title={title} description={description}>
  <nav class="breadcrumbs"><a href="/">Home</a><span>/</span><a href="/materials/">Materials</a><span>/</span><span>{material.name}</span></nav>
  <article class="section">
    <section class="answer-card"><span class={`verdict ${verdictClass}`}>{verdictLabels[material.defaultVerdict]}</span><h1>{title}</h1><p class="answer-text">{material.shortAnswer}</p></section>
    <section class="section"><h2>Caveats</h2><ul class="caveats">{material.caveats.map((c)=><li><Icon name="warning" /><span>{c}</span></li>)}</ul></section>
    <section class="section"><div class="section-head"><h2>Related items</h2><p>Specific examples that include {material.name}.</p></div><div class="grid">{related.map((item)=><a class="card" href={`/items/${item.slug}/`}><strong>{item.name}</strong><p>{item.shortAnswer}</p></a>)}</div></section>
  </article>
</BaseLayout>

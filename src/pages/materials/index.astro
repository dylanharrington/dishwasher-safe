---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { materials, verdictLabels } from '../../data/items';
---
<BaseLayout title="Dishwasher-safe materials" description="Dishwasher guidance for stainless steel, silicone, wood, glass, plastic, nonstick, cast iron, and ceramic.">
  <nav class="breadcrumbs"><a href="/">Home</a><span>/</span><span>Materials</span></nav>
  <section class="section">
    <div class="section-head"><h1>Dishwasher-safe materials</h1><p>General rules by material, with exceptions.</p></div>
    <div class="grid">
      {materials.map((material)=>(
        <a class="card" href={`/materials/${material.slug}/`}><span class="icon-badge"><Icon name="sparkle" /></span><strong>{material.name}</strong><p><span class="chip">{verdictLabels[material.defaultVerdict]}</span></p><p>{material.shortAnswer}</p></a>
      ))}
    </div>
  </section>
</BaseLayout>
